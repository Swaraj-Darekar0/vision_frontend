{
  "expo": {
    "name": "Vison",
    "slug": "vision",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "icon": "./assets/images/vision_app_logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/notification_vision_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SpeakingCoach uses the camera to record your presentations.",
        "NSMicrophoneUsageDescription": "SpeakingCoach uses the microphone to record your speech.",
        "NSPhotoLibraryAddUsageDescription": "SpeakingCoach saves your recordings to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/vision_app_logo.png",
        "backgroundImage": "./assets/images/vision_app_logo.png",
        "monochromeImage": "./assets/images/vision_app_logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Vision",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": "SpeakingCoach uses the microphone to capture your speech."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermission": "SpeakingCoach uses the camera to record your presentations.",
          "microphonePermission": "SpeakingCoach uses the microphone to capture your speech.",
          "enableFrameProcessors": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow SpeakingCoach to access your library.",
          "savePhotosPermission": "Allow SpeakingCoach to save your recordings."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification_vision_logo.png",
          "color": "#1152D4",
          "sounds": [
            "./assets/EXTRA/pop_soound_effect.mp3"
          ]
        }
      ],
      "expo-sharing",
      "expo-video",
      "expo-audio",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "904a94a9-ea52-4b9c-9bf6-c3722ef6e6aa"
      }
    },
    "owner": "swarajdarekar"
  }
}
